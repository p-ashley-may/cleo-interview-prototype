{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "Modules/*": ["../../app/javascript/modules/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
